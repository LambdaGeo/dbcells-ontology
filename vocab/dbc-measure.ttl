@prefix rdf:          <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:         <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:          <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:      <http://purl.org/dc/terms/> .
@prefix qb:           <http://purl.org/linked-data/cube#> .
@prefix sdmx-measure: <http://purl.org/linked-data/sdmx/2009/measure#> .
@prefix skos:         <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix sweet-space:  <http://sweetontology.net/propSpaceDistance/> .
@prefix dbc-m:        <https://purl.org/linked-data/dbcells/measure#> .

@base <https://purl.org/linked-data/dbcells/measure#> .

# ------------------------------------------------------------------
# Ontology header
# ------------------------------------------------------------------

<https://purl.org/linked-data/dbcells/measure>
    a owl:Ontology ;
    rdfs:label        "DBCells Measure Vocabulary"@en ;
    rdfs:comment      "Defines measure properties representing the spatial aggregation operations commonly used in land use and land cover change models."@en ;
    dcterms:created   "2023-03-17"^^xsd:date ;
    dcterms:modified  "2025-07-01"^^xsd:date ;
    dcterms:creator   <https://github.com/LambdaGeo> ;
    dcterms:license   <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo   "1.0.0" ;
    rdfs:seeAlso      <https://lambdageo.github.io/dbcells-ontology/measure> .

# ------------------------------------------------------------------
# Measures
# ------------------------------------------------------------------

dbc-m:distance
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Euclidean distance"@en ;
    rdfs:comment    "Minimum Euclidean distance from the centroid of a cell to the nearest geographic feature, expressed in meters."@en ;
    skos:notation   "distance" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:seeAlso    sweet-space:Distance ;
    rdfs:range      xsd:decimal .

dbc-m:mean
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Arithmetic mean"@en ;
    rdfs:comment    "Arithmetic mean of the values of a given variable within a cell, used to aggregate data from higher-resolution sources."@en ;
    skos:notation   "mean" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:mode
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Mode"@en ;
    rdfs:comment    "Most frequently occurring value of a given variable within a cell."@en ;
    skos:notation   "mode" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:minimum
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Minimum"@en ;
    rdfs:comment    "Minimum value of a given variable observed within a cell."@en ;
    skos:notation   "minimum" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:maximum
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Maximum"@en ;
    rdfs:comment    "Maximum value of a given variable observed within a cell."@en ;
    skos:notation   "maximum" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:sum
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Sum"@en ;
    rdfs:comment    "Sum of the values of a given variable within a cell."@en ;
    skos:notation   "sum" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:count
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Count"@en ;
    rdfs:comment    "Number of occurrences of a given feature or class within a cell."@en ;
    skos:notation   "count" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:integer .

dbc-m:percentage
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Percentage"@en ;
    rdfs:comment    "Percentage of a cell area covered by a given feature or land cover class, expressed as a value between 0 and 100."@en ;
    skos:notation   "percentage" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:stdev
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Standard deviation"@en ;
    rdfs:comment    "Standard deviation of the values of a given variable within a cell."@en ;
    skos:notation   "stdev" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:area
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Area"@en ;
    rdfs:comment    "Total area covered by a given feature or land cover class within a cell, expressed in square meters."@en ;
    skos:notation   "area" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:decimal .

dbc-m:presence
    a               rdf:Property, qb:MeasureProperty ;
    rdfs:label      "Presence"@en ;
    rdfs:comment    "Binary indicator of whether a given feature or class is present within a cell. 1 indicates presence, 0 indicates absence."@en ;
    skos:notation   "presence" ;
    rdfs:subPropertyOf sdmx-measure:obsValue ;
    rdfs:range      xsd:boolean .
