@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix qb:       <http://purl.org/linked-data/cube#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix dbc-a:    <https://purl.org/linked-data/dbcells/attribute#> .
@prefix dbc-c:    <https://purl.org/linked-data/dbcells/code#> .

@base <https://purl.org/linked-data/dbcells/attribute#> .

# ------------------------------------------------------------------
# Ontology header
# ------------------------------------------------------------------

<https://purl.org/linked-data/dbcells/attribute>
    a               owl:Ontology ;  # MUDOU AQUI (de rdf:Property para owl:Ontology)
    rdfs:label      "DBCells Attribute Vocabulary"@en ;
    rdfs:comment    "Defines attribute properties..."@en ;
    dcterms:title   "DBCells Attribute Vocabulary"@en ; # Recomendado para o pyLODE
    dcterms:created  "2023-03-17"^^xsd:date ;
    dcterms:modified "2025-07-01"^^xsd:date ;
    # ... resto dos campos ...
    owl:versionInfo  "1.0.0" .

# ------------------------------------------------------------------
# Attributes
# ------------------------------------------------------------------

dbc-a:feature
    a               rdf:Property, qb:AttributeProperty ;
    rdfs:label      "feature"@en ;
    rdfs:comment    "The geographic feature or land cover class to which the measure relates. For example, a distance measure may relate to roads, rivers or urban areas. Values must be drawn from the DBCells feature code list."@en ;
    skos:notation   "feature" ;
    rdfs:range      skos:Concept ;
    qb:codeList     dbc-c:featureCodeList .

dbc-a:sourceFile
    a               rdf:Property, qb:AttributeProperty ;
    rdfs:label      "source file"@en ;
    rdfs:comment    "URI of the raw input data file used to compute the measure. Supports reproducibility by identifying the original data source, such as a shapefile, GeoPackage, GeoTIFF or NetCDF file."@en ;
    skos:notation   "sourceFile" ;
    rdfs:range      rdfs:Resource .

dbc-a:layer
    a               rdf:Property, qb:AttributeProperty ;
    rdfs:label      "layer"@en ;
    rdfs:comment    "Name of the specific layer within the source file used to compute the measure. Required when the source format supports multiple layers, such as GeoPackage or NetCDF. Optional for single-layer formats such as Shapefile or GeoTIFF."@en ;
    skos:notation   "layer" ;
    rdfs:range      xsd:string .

dbc-a:scriptFile
    a               rdf:Property, qb:AttributeProperty ;
    rdfs:label      "script file"@en ;
    rdfs:comment    "URI of the script used to compute the measure from the source data. Supports full reproducibility of the data generation process. Typically a Lua script executed in the TerraME environment."@en ;
    skos:notation   "scriptFile" ;
    rdfs:range      rdfs:Resource .

dbc-a:urlData
    a               rdf:Property, qb:AttributeProperty ;
    rdfs:label      "data URL"@en ;
    rdfs:comment    "URL of a published dataset or data repository where the source data can be accessed or downloaded. Complements sourceFile when the data is publicly available online."@en ;
    skos:notation   "urlData" ;
    rdfs:range      rdfs:Resource .